      "id": "418e13d3-d308-4315-a7fd-f1b1b34aacb2",
      "name": "Sheets: Read All for Report",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        1600,
        1168
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "NznwYiyQzqjAKGIB",
          "name": "Google Sheets account"
        }
