    {
      "parameters": {
        "jsCode": "// Filtrer les posts publiés depuis 48h sans feedback\nconst cutoff = new Date(Date.now() - 48 * 60 * 60 * 1000);\n\nconst pending = $input.all().filter(row => {\n  const r = row.json;\n  return r.Status === 'posted'\n    && (!r.FeedbackCollected || r.FeedbackCollected === 'FALSE')\n    && r.PostedAt\n    && new Date(r.PostedAt) < cutoff;\n});\n\nif (pending.length === 0) return [{ json: { hasPending: false } }];\n\nreturn pending.map(row => ({ json: { ...row.json, hasPending: true } }));"
      },
      "id": "f184d1a4-0878-4f56-94ed-cd2f932c6b47",
      "name": "Filter Pending Feedback",
      "type": "n8n-nodes-base.code",
