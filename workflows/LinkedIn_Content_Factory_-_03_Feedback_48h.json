      "id": "b0987700-0e56-404b-8af5-7ffd907a759d",
      "name": "LinkedIn: Get Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1792,
        928
      ]
    },
    {
      "parameters": {
        "jsCode": "const linkedinData = $input.first().json;\nconst postData     = $('Loop: Fetch Stats').first().json;\n\nlet likes = 0, comments = 0, shares = 0, clicks = 0, impressions = 0;\ntry {\n  const results = linkedinData.results || {};\n  const key     = Object.keys(results)[0];\n  if (key) {\n    const meta  = results[key];\n    const stats = meta.totalSocialActivityCounts || {};\n    likes       = stats.numLikes    || 0;\n    comments    = stats.numComments || 0;\n    shares      = stats.numShares   || 0;\n    clicks      = stats.numClicks   || 0;\n    impressions = stats.numImpressions || 0;\n  }\n} catch(e) { console.log('Stats parse error:', e.message); }\n\nconst totalEngagement  = likes + comments + shares + clicks;\nconst engagementRate   = impressions > 0 ? parseFloat(((totalEngagement / impressions) * 100).toFixed(2)) : 0;\n\nreturn [{ json: {\n  id:              postData.ID,\n  impressions,\n  likes,\n  comments,\n  shares,\n  clicks,\n  totalEngagement,\n  engagementRate,\n  isTopPerformer:  totalEngagement > 50\n} }];"
      },
      "id": "c73129dc-3804-43d7-8b93-0093d8fb68b9",
      "name": "Parse Stats",
