    {
      "parameters": {
        "jsCode": "const posts = $input.all()\n  .filter(p => p.json.Status === 'posted' && p.json.FeedbackCollected === 'TRUE')\n  .sort((a, b) => (Number(b.json.TotalEngagement) || 0) - (Number(a.json.TotalEngagement) || 0));\n\nif (posts.length === 0) return [{ json: { report: 'Pas encore de données feedback.' } }];\n\nconst byType = {};\nposts.forEach(p => {\n  const t = p.json.Type || 'unknown';\n  if (!byType[t]) byType[t] = { count: 0, totalEng: 0 };\n  byType[t].count++;\n  byType[t].totalEng += Number(p.json.TotalEngagement) || 0;\n});\nObject.keys(byType).forEach(t => { byType[t].avgEng = Math.round(byType[t].totalEng / byType[t].count); });\n\nconst topType = Object.entries(byType).sort((a, b) => b[1].avgEng - a[1].avgEng)[0];\nconst top3 = posts.slice(0, 3).map(p =>\n  `• [${p.json.Type}] ${(p.json.Hook || p.json.Content || '').substring(0, 55)}... → ${p.json.TotalEngagement || 0} eng.`\n).join('\\n');\n\nconst statsLines = Object.entries(byType)\n  .map(([t, d]) => `• ${t}: ${d.count} posts, avg ${d.avgEng} eng.`)\n  .join('\\n');\n\nconst report = `📊 *Rapport Feedback LinkedIn*\\n\\n*Pattern gagnant :* ${topType?.[0] || 'N/A'} (avg ${topType?.[1]?.avgEng || 0} eng.)\\n\\n*Top 3 posts :*\\n${top3}\\n\\n*Stats par type :*\\n${statsLines}\\n\\n💡 Prioriser le type \\'${topType?.[0] || 'confession'}\\' pour demain.`;\n\nreturn [{ json: { report } }];"
      },
